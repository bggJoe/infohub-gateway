NODE_ENV=development
PORT=8080

AUTH_MODE=dev
DEV_USER_EMAIL=joelovesband@gmail.com
ALLOWED_USERS=joelovesband@gmail.com

# Production:
# AUTH_MODE=iap
# IAP_AUDIENCE=/projects/{PROJECT_NUMBER}/locations/{REGION}/services/infohub-gateway

N8N_ACTION_ITEMS_URL=https://example.invalid/webhook/action-items
N8N_AUTH_MODE=jwt
N8N_JWT_PRIVATE_KEY_PEM=replace-with-local-rs256-private-key-pem
N8N_JWT_ISSUER=infohub-gateway
N8N_JWT_AUDIENCE=infohub-n8n
N8N_JWT_SCOPE=infohub:action-items:read
N8N_JWT_TTL_SECONDS=60

# Legacy fallback only:
# N8N_AUTH_MODE=header
# N8N_API_AUTH_HEADER_NAME=x-infohub-api-key
# N8N_API_AUTH_HEADER_VALUE=replace-with-secret-from-local-env

N8N_TIMEOUT_MS=8000
N8N_MAX_RETRIES=1

LOG_LEVEL=info
